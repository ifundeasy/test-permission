{
  "$comment": "Application-level permission registry for the imagined 'Nusantara ERP' (SaaS, B2B+B2C). These are METADATA, not running servers: 5 microservices, every backend endpoint, UI page, and UI component is a first-class permission target. IDs are derived as ep/<svc>/<key>, pg/<svc>/<key>, cmp/<svc>/<page>/<name> (SpiceDB object IDs forbid ':'). Actions: endpoint=execute, page=view, component=render.",
  "services": [
    {
      "key": "identity",
      "name": "Identity & Organization Service",
      "endpoints": [
        { "key": "org-list", "method": "GET", "path": "/v1/orgs" },
        { "key": "org-create", "method": "POST", "path": "/v1/orgs" },
        { "key": "org-detail", "method": "GET", "path": "/v1/orgs/{id}" },
        { "key": "org-update", "method": "PATCH", "path": "/v1/orgs/{id}" },
        { "key": "persona-list", "method": "GET", "path": "/v1/personas" },
        { "key": "persona-create", "method": "POST", "path": "/v1/personas" },
        { "key": "persona-update", "method": "PATCH", "path": "/v1/personas/{id}" },
        { "key": "role-create", "method": "POST", "path": "/v1/roles" },
        { "key": "division-create", "method": "POST", "path": "/v1/divisions" },
        { "key": "invitation-send", "method": "POST", "path": "/v1/invitations" }
      ],
      "pages": [
        { "key": "org-list", "route": "/orgs", "components": ["header-summary", "filter-bar", "search-box", "org-grid", "row-actions", "btn-create-org", "btn-export", "pagination", "side-panel", "audit-trail"] },
        { "key": "org-detail", "route": "/orgs/:id", "components": ["org-header", "subsidiary-tree", "division-list", "role-matrix", "btn-edit-org", "btn-add-subsidiary", "member-grid", "activity-feed", "danger-zone", "audit-trail"] },
        { "key": "org-tree", "route": "/orgs/tree", "components": ["tree-canvas", "depth-selector", "node-tooltip", "btn-expand-all", "btn-collapse-all", "legend-panel", "search-node", "mini-map", "export-svg", "zoom-controls"] },
        { "key": "persona-list", "route": "/personas", "components": ["header-summary", "filter-bar", "search-box", "persona-grid", "row-actions", "btn-invite", "btn-export", "pagination", "bulk-actions", "status-chips"] },
        { "key": "persona-detail", "route": "/personas/:id", "components": ["profile-card", "role-badges", "division-badge", "clearance-meter", "btn-edit", "btn-suspend", "session-list", "permission-explorer", "linked-account", "audit-trail"] },
        { "key": "role-settings", "route": "/settings/roles", "components": ["role-grid", "btn-create-role", "permission-matrix", "default-role-banner", "custom-role-list", "row-actions", "search-box", "import-export", "diff-viewer", "audit-trail"] },
