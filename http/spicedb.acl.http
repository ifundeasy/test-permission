# ACL × SpiceDB (server) — acl_document#viewer / #editor
# view = viewer + editor; a viewer cannot edit. Same dataset/IDs as cedar.acl.http.

@host = http://localhost:8080
@spicedb = http://localhost:8443
@key = benchkey

### ALLOW — persona has a direct viewer grant, via facade
POST {{host}}/v1/authorize
Content-Type: application/json

{
  "engine": "spicedb",
  "model": "acl",
  "principal": "psn-042051",
  "action": "acl.view",
  "resource_type": "AclDocument",
  "resource": "acldoc-000171"
}

### DENY — the same viewer is not an editor, so edit is refused, via facade
POST {{host}}/v1/authorize
Content-Type: application/json

{
  "engine": "spicedb",
  "model": "acl",
  "principal": "psn-042051",
  "action": "acl.edit",
  "resource_type": "AclDocument",
  "resource": "acldoc-000171"
}

### RAW — SpiceDB HTTP gateway
POST {{spicedb}}/v1/permissions/check
Authorization: Bearer {{key}}
Content-Type: application/json

{
  "consistency": { "fullyConsistent": true },
  "resource": { "objectType": "acl_document", "objectId": "acldoc-000171" },
  "permission": "view",
  "subject": { "object": { "objectType": "persona", "objectId": "psn-042051" } }
}
