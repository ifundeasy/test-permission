# ACL × SpiceDB (server) — acl_document#viewer / #editor
# Same dataset/IDs as cedar.acl.http — decisions must match.

@host = http://localhost:8080
@spicedb = http://localhost:8443
@key = benchkey

### ALLOW — direct editor grant, via facade
POST {{host}}/v1/authorize
Content-Type: application/json

{
  "engine": "spicedb",
  "model": "acl",
  "principal": "psn-178603",
  "action": "acl.edit",
  "resource_type": "AclDocument",
  "resource": "acldoc-000065"
}

### DENY — no grant, via facade
POST {{host}}/v1/authorize
Content-Type: application/json

{
  "engine": "spicedb",
  "model": "acl",
  "principal": "psn-013997",
  "action": "acl.view",
  "resource_type": "AclDocument",
  "resource": "acldoc-000065"
}

### RAW — SpiceDB HTTP gateway
POST {{spicedb}}/v1/permissions/check
Authorization: Bearer {{key}}
Content-Type: application/json

{
  "consistency": { "fullyConsistent": true },
  "resource": { "objectType": "acl_document", "objectId": "acldoc-000065" },
  "permission": "edit",
  "subject": { "object": { "objectType": "persona", "objectId": "psn-178603" } }
}
