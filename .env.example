# Copy to .env and fill in real values. Never commit .env (see .gitignore).
# Read from the real environment by the Go service (internal/config); `make run`
# loads this file for local dev, and docker-compose.yml injects it via env_file.

DB_HOST=localhost            # use "localhost" for local `npm start`; compose overrides it to "postgres"
DB_PORT=5432
DB_USER=<your-db-user>
DB_PASSWORD=<your-db-password>
DB_NAME=authz
PORT=8080

# Optional: override the Cedar policy file path (defaults to policies/policy.cedar)
# POLICY_FILE=./policies/policy.cedar
