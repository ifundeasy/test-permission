# Copy to .env and fill in real values. Never commit .env (see .gitignore).
# Read by docker-compose.yml and by the Go binaries (facade, seeder, bench);
# `make run` loads this file for local runs.

# --- Postgres (one server, three roles) ---
DB_HOST=localhost            # "localhost" for local runs; compose overrides to "postgres"
DB_PORT=5432
DB_USER=<admin-user>         # admin/owner of the database (POSTGRES_USER)
DB_PASSWORD=<admin-password>
DB_NAME=authz

CEDAR_DB_PASSWORD=<cedar-role-password>      # role "cedar"   → schema "cedar"   (app data)
SPICEDB_DB_PASSWORD=<spicedb-role-password>  # role "spicedb" → schema "spicedb" (SpiceDB datastore)

# --- SpiceDB ---
SPICEDB_ENDPOINT=localhost:50051             # compose overrides to "spicedb:50051"
SPICEDB_PRESHARED_KEY=<preshared-key>
SPICEDB_GRPC_PORT=50051
SPICEDB_HTTP_PORT=8443

# --- Facade ---
PORT=8080
